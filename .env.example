# DICA Decorator - Frontend env template
# Copy to .env.local and fill in real values. NEVER commit .env or .env.local.

# Supabase (frontend) - safe to expose, protected by Row Level Security
VITE_SUPABASE_PROJECT_ID="<your-project-ref>"
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-supabase-anon-key>"

# Edge Function secrets (NEVER expose to frontend, set via `supabase secrets set`):
#   SUPABASE_SERVICE_ROLE_KEY=...
#   GOOGLE_AI_API_KEY=...
#   AI_GATEWAY_API_KEY=...
#   AI_GATEWAY_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
